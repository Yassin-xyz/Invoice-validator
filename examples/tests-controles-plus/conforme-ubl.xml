    <cac:AllowanceCharge>
      <cbc:ChargeIndicator>false</cbc:ChargeIndicator>
      <cbc:Amount currencyID="EUR">1.00</cbc:Amount>
    </cac:AllowanceCharge>
    <cac:Price>
      <!-- 20 − 3 = 17 ✓ -->
      <cbc:PriceAmount currencyID="EUR">17.00</cbc:PriceAmount>
      <cbc:BaseQuantity unitCode="C62">1</cbc:BaseQuantity>
      <cac:AllowanceCharge>
        <cbc:ChargeIndicator>false</cbc:ChargeIndicator>
        <cbc:Amount currencyID="EUR">3.00</cbc:Amount>
        <cbc:BaseAmount currencyID="EUR">20.00</cbc:BaseAmount>
      </cac:AllowanceCharge>
    </cac:Price>
  </cac:InvoiceLine>
